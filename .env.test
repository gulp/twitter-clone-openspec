# Test environment configuration
# Used by E2E tests with docker-compose.test.yml

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/twitter_clone_test"

# Redis
REDIS_URL="redis://localhost:6380"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="test-secret-for-e2e-tests-only-not-for-production"

# OAuth - Test credentials (not used in E2E, but required by schema)
GOOGLE_CLIENT_ID="test-google-client-id"
GOOGLE_CLIENT_SECRET="test-google-client-secret"
GITHUB_CLIENT_ID="test-github-client-id"
GITHUB_CLIENT_SECRET="test-github-client-secret"

# S3/MinIO
S3_ENDPOINT="http://localhost:9002"
S3_REGION="us-east-1"
S3_BUCKET="twitter-clone"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_PUBLIC_URL="http://localhost:9002/twitter-clone"

# SMTP/Email (Ethereal test account)
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_USER="test-user"
SMTP_PASS="test-pass"
EMAIL_FROM="noreply@twitter-clone.test"

# App
APP_ORIGIN="http://localhost:3000"
ALLOWED_PREVIEW_ORIGINS="http://localhost:3000"

# Node environment
NODE_ENV="test"
